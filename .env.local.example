# Copy this file to .env.local and fill in your values
# Get these from: https://supabase.com/dashboard -> your project -> Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Keep this secret - never expose in frontend code
# Get from: Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Get from: https://resend.com -> API Keys
RESEND_API_KEY=your-resend-api-key-here

# The "from" address for emails - must be a verified domain in Resend
EMAIL_FROM=noreply@thmtsgroup.com

# Your app URL (use http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
